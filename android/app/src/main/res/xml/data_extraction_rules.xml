<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Backup all shared preferences and files by default -->
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </cloud-backup>
    
    <!-- Device-to-device transfer (Android 12+) -->
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
